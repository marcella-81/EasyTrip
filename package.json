{
  "name": "easytrip",
  "private": true,
  "packageManager": "npm@10.9.4",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "test": "turbo test",
    "test:watch": "turbo test:watch",
    "db:up": "docker compose up -d postgres postgres-test",
    "db:down": "docker compose down"
  },
  "devDependencies": {
    "turbo": "^2.5.4"
  }
}
