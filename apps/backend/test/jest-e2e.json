{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@easytrip/shared$": "<rootDir>/../../../packages/shared/src/index.ts",
    "^@easytrip/shared/(.*)$": "<rootDir>/../../../packages/shared/src/$1"
  },
  "globalSetup": "<rootDir>/setup-e2e.ts"
}
